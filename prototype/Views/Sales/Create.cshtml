@model IEnumerable<prototype.Models.Product>

@{
    ViewData["Title"] = "New Sale (POS)";
}

<div class="container-fluid pos-container py-3">
    <div class="row">
        <!-- Left Column: Product Selection -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-0">
                    <h5 class="mb-0 text-primary fw-bold">
                        <i class="fas fa-th-large me-2 text-primary"></i>Product Selection
                    </h5>
                    <div class="search-box-container w-50">
                        <i class="fas fa-search"></i>
                        <input type="text" class="form-control border-0 shadow-sm" placeholder="Search products...">
                    </div>
                </div>
                <div class="card-body bg-white pt-0">
                    <div class="row g-4">
                        @foreach (var item in Model)
                        {
                            <div class="col-xl-4 col-md-6">
                                <div class="pos-product-card border shadow-sm">
                                    <div class="pos-product-name text-primary">@item.Name</div>
                                    <div class="pos-product-price text-success">₱@item.Price.ToString("N2")</div>
                                    <div class="pos-product-stock text-muted">Stock: @item.StockQuantity</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Current Order -->
        <div class="col-lg-4">
            <div class="card order-summary-card shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 text-primary fw-bold">
                        <i class="fas fa-shopping-cart me-2"></i>Current Order
                    </h5>
                </div>
                <div class="card-body d-flex flex-column p-4">
                    <div class="table-responsive flex-grow-1">
                        <table class="table order-table border-0">
                            <thead>
                                <tr class="border-bottom">
                                    <th class="border-0 ps-0">ITEM</th>
                                    <th class="border-0 text-center">QTY</th>
                                    <th class="border-0 text-end pe-0">TOTAL</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Empty state or items would go here -->
                                <tr>
                                    <td colspan="3" class="text-center py-5 text-muted border-0">
                                        <i class="fas fa-shopping-basket fa-3x mb-3 d-block opacity-25"></i>
                                        Your cart is empty
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="order-totals mt-auto pt-4">
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-dark fw-bold h5 mb-0">Subtotal:</span>
                            <span class="fw-bold h5 mb-0">₱0.00</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-dark fw-bold h5 mb-0">Tax (0%):</span>
                            <span class="fw-bold h5 mb-0">₱0.00</span>
                        </div>
                        <div class="d-flex justify-content-between mb-4 align-items-center">
                            <h2 class="text-primary fw-bold mb-0">Total:</h2>
                            <h2 class="text-primary fw-bold mb-0">₱0.00</h2>
                        </div>

                        <div class="d-grid gap-3">
                            <button class="btn btn-success btn-lg py-3 fw-bold rounded-3">
                                <i class="fas fa-check-circle me-2"></i>Complete Sale
                            </button>
                            <button class="btn btn-danger btn-lg py-2 fw-bold rounded-3">
                                <i class="fas fa-trash-alt me-2"></i>Clear Cart
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Placeholder for POS interactions
            $('.pos-product-card').on('click', function() {
                // Animation effect
                $(this).addClass('bg-light');
                setTimeout(() => {
                    $(this).removeClass('bg-light');
                }, 100);
            });
        });
    </script>
}
