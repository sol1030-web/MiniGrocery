@{
    ViewData["Title"] = "Sales History";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h1 class="h3 mb-0 text-gray-800">Sales History</h1>
            <p class="text-muted">Review past transactions</p>
        </div>
        <div class="col-auto">
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus me-2"></i>New Sale (POS)
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body py-5 text-center text-muted">
            <i class="fas fa-history fa-4x mb-3 opacity-25"></i>
            <h4>No sales records found</h4>
            <p>Start a new sale to see records here.</p>
        </div>
    </div>
</div>
