@model MiniGrocery.Web.Models.PurchaseHistoryViewModel

@{
    ViewData["Title"] = "Purchase History";
}

<div class="container mt-4">
    <h2>Purchase Transaction History</h2>
    
    <div class="table-responsive">
        <table class="table table-striped table-bordered">
            <thead class="thead-dark">
                <tr>
                    <th>ID</th>
                    <th>Date</th>
                    <th>Supplier</th>
                    <th>Buyer (Staff)</th>
                    <th>Items</th>
                    <th>Total Cost</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var transaction in Model.Transactions)
                {
                    <tr>
                        <td>@transaction.Id</td>
                        <td>@transaction.TransactionDate.ToPhTime()</td>
                        <td>@(transaction.Supplier?.Name ?? "Unknown")</td>
                        <td>@(transaction.User?.UserName ?? "Unknown")</td>
                        <td>
                            <ul>
                                @foreach (var item in transaction.PurchaseItems)
                                {
                                    <li>@item.Product?.Name x @item.Quantity (@item.UnitCost.ToString("C"))</li>
                                }
                            </ul>
                        </td>
                        <td>@transaction.TotalCost.ToString("C")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <nav class="mt-3">
        <ul class="pagination justify-content-end">
            <li class="page-item @(Model.Pagination.HasPrevious ? "" : "disabled")">
                <a class="page-link" asp-action="Index" asp-route-page="@(Model.Pagination.Page - 1)" asp-route-pageSize="@(Model.Pagination.PageSize)">Previous</a>
            </li>
            @for (int i = 1; i <= Model.Pagination.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Pagination.Page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-pageSize="@(Model.Pagination.PageSize)">@i</a>
                </li>
            }
            <li class="page-item @(Model.Pagination.HasNext ? "" : "disabled")">
                <a class="page-link" asp-action="Index" asp-route-page="@(Model.Pagination.Page + 1)" asp-route-pageSize="@(Model.Pagination.PageSize)">Next</a>
            </li>
        </ul>
    </nav>
</div>
