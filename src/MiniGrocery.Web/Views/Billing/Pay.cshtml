@model MiniGrocery.Web.Models.MakePaymentViewModel

<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Record Payment</h1>

    <div class="row">
        <div class="col-lg-6">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">New Payment for Invoice #INV-@Model.InvoiceId</h6>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <div class="row">
                            <div class="col-6">Total Amount:</div>
                            <div class="col-6 text-right font-weight-bold">@Model.TotalAmount.ToString("C")</div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-6">Pending Balance:</div>
                            <div class="col-6 text-right font-weight-bold text-danger">@Model.PendingBalance.ToString("C")</div>
                        </div>
                    </div>

                    <form asp-action="Pay" method="post">
                        <input type="hidden" asp-for="InvoiceId" />
                        <input type="hidden" asp-for="TotalAmount" />
                        <input type="hidden" asp-for="PendingBalance" />
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="form-group mb-3">
                            <label asp-for="PaymentAmount" class="control-label">Payment Amount</label>
                            <div class="input-group">
                                <span class="input-group-text">₱</span>
                                <input asp-for="PaymentAmount" class="form-control" type="number" step="0.01" min="0.01" max="@Model.PendingBalance" />
                            </div>
                            <span asp-validation-for="PaymentAmount" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="PaymentMethod" class="control-label">Payment Method</label>
                            <select asp-for="PaymentMethod" class="form-control">
                                <option value="Cash">Cash</option>
                                <option value="Credit Card">Credit Card</option>
                                <option value="Debit Card">Debit Card</option>
                                <option value="Bank Transfer">Bank Transfer</option>
                                <option value="Mobile Payment">Mobile Payment</option>
                            </select>
                            <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="ReferenceNumber" class="control-label">Reference Number (Optional)</label>
                            <input asp-for="ReferenceNumber" class="form-control" placeholder="Transaction ID, Check #, etc." />
                            <span asp-validation-for="ReferenceNumber" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <button type="submit" class="btn btn-success btn-block">
                                <i class="fas fa-check"></i> Process Payment
                            </button>
                            <a asp-action="Details" asp-route-id="@Model.InvoiceId" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
