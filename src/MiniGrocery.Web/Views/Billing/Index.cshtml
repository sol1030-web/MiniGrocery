@model MiniGrocery.Web.Models.BillingIndexViewModel

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 text-gray-800">Billing & Invoices</h1>
    </div>

    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="table-responsive" style="max-height: 600px;">
                <table class="table table-bordered table-hover table-modern" width="100%" cellspacing="0">
                    <thead class="sticky-top bg-light">
                        <tr>
                            <th>Invoice #</th>
                            <th>Date</th>
                            <th>Processed By</th>
                            <th>Total</th>
                            <th>Paid</th>
                            <th>Balance</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>INV-@item.Id</td>
                                <td>@item.Date.ToString("d")</td>
                                <td>@item.CustomerName</td>
                                <td class="text-end">@item.TotalAmount.ToString("C")</td>
                                <td class="text-end">@item.PaidAmount.ToString("C")</td>
                                <td class="font-weight-bold text-end">@item.Balance.ToString("C")</td>
                                <td>
                                    @if(item.Status == "Paid") { <span class="badge modern-badge modern-badge-success">Paid</span> }
                                    else if(item.Status == "Pending") { <span class="badge modern-badge modern-badge-warning">Pending</span> }
                                    else if(item.Status == "Partially Paid") { <span class="badge modern-badge modern-badge-info">Partial</span> }
                                    else { <span class="badge bg-secondary">@item.Status</span> }
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" 
                                       class="btn-modern btn-icon btn-view me-1" 
                                       title="View" aria-label="View">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    @if(item.Balance > 0)
                                    {
                                        <a asp-action="Pay" asp-route-id="@item.Id" class="btn-modern btn-icon btn-pay" title="Pay" aria-label="Pay">
                                            <i class="fas fa-credit-card"></i>
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <nav class="mt-3">
                <ul class="pagination justify-content-end">
                    <li class="page-item @(Model.Pagination.HasPrevious ? "" : "disabled")">
                        <a class="page-link" asp-action="Index" asp-route-status="@Model.Status" asp-route-page="@(Model.Pagination.Page - 1)" asp-route-pageSize="@(Model.Pagination.PageSize)">Previous</a>
                    </li>
                    @for (int i = 1; i <= Model.Pagination.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Pagination.Page ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-status="@Model.Status" asp-route-page="@i" asp-route-pageSize="@(Model.Pagination.PageSize)">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.Pagination.HasNext ? "" : "disabled")">
                        <a class="page-link" asp-action="Index" asp-route-status="@Model.Status" asp-route-page="@(Model.Pagination.Page + 1)" asp-route-pageSize="@(Model.Pagination.PageSize)">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>
