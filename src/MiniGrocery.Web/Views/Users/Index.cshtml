@model List<MiniGrocery.Web.Models.UserViewModel>

@{
    ViewData["Title"] = "User Management";
}

<div class="container-fluid mt-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">User Management</h1>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="fas fa-user-plus fa-sm text-white-50 mr-1"></i> Create New User
        </a>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">System Users</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-modern table-hover" width="100%" cellspacing="0">
                    <thead class="sticky-top bg-light">
                        <tr>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>@user.FullName</td>
                                <td>@user.Email</td>
                                <td>
                                    @switch (user.Role)
                                    {
                                        case "System Administrator":
                                            <span class="badge modern-badge modern-badge-danger">@user.Role</span>
                                            break;
                                        case "Manager":
                                            <span class="badge modern-badge modern-badge-info">@user.Role</span>
                                            break;
                                        case "Sales Staff":
                                            <span class="badge modern-badge modern-badge-success">@user.Role</span>
                                            break;
                                        case "Inventory Clerk":
                                            <span class="badge modern-badge modern-badge-cyan">@user.Role</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary text-white">@user.Role</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    @if (User.Identity?.Name != user.Email)
                                    {
                                        <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-outline-primary btn-sm me-1" title="Edit User">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form asp-action="Archive" asp-route-id="@user.Id" method="post" onsubmit="return confirm('Archive this user? They will be locked out.');" style="display:inline;">
                                            <button type="submit" class="btn btn-outline-secondary btn-sm" title="Archive User">
                                                <i class="fas fa-archive"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Current User</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
