@model MiniGrocery.Web.Models.InventoryHistoryPageViewModel

<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Inventory Movement History</h1>

    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary">Transaction Logs (Last 100)</h6>
            <a asp-action="Index" class="btn btn-sm btn-primary">Back to Dashboard</a>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-modern table-hover" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Product</th>
                            <th>Qty Change</th>
                            <th>Note</th>
                            <th>User ID</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.Date.ToPhTime().ToString("g")</td>
                                <td>
                                    @if (item.Type == "Sale") { <span class="badge modern-badge modern-badge-warning">Sale</span> }
                                    else if (item.Type == "Purchase") { <span class="badge modern-badge modern-badge-success">Purchase</span> }
                                    else if (item.Type == "Adjustment") { <span class="badge modern-badge modern-badge-cyan">Adjustment</span> }
                                    else if (item.Type == "Reprice") { <span class="badge modern-badge modern-badge-info">Reprice</span> }
                                    else if (item.Type == "Archive") { <span class="badge modern-badge modern-badge-danger">Archive</span> }
                                    else { <span class="badge bg-secondary">@item.Type</span> }
                                </td>
                                <td>@item.ProductName</td>
                                <td class="@(item.QuantityChange > 0 ? "text-success" : "text-danger") font-weight-bold">
                                    @(item.QuantityChange > 0 ? "+" : "")@item.QuantityChange
                                </td>
                                <td>@item.Note</td>
                                <td><small class="text-muted">@item.ByUserId</small></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <nav class="mt-3">
                <ul class="pagination justify-content-end">
                    <li class="page-item @(Model.Pagination.HasPrevious ? "" : "disabled")">
                        <a class="page-link" asp-action="History" asp-route-page="@(Model.Pagination.Page - 1)" asp-route-pageSize="@(Model.Pagination.PageSize)">Previous</a>
                    </li>
                    @for (int i = 1; i <= Model.Pagination.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Pagination.Page ? "active" : "")">
                            <a class="page-link" asp-action="History" asp-route-page="@i" asp-route-pageSize="@(Model.Pagination.PageSize)">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.Pagination.HasNext ? "" : "disabled")">
                        <a class="page-link" asp-action="History" asp-route-page="@(Model.Pagination.Page + 1)" asp-route-pageSize="@(Model.Pagination.PageSize)">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>
